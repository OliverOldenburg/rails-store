<p><%= link_to "Back", products_path %></p>

<section class="product">
  <% if @product.featured_image.attached? %>
    <div class="product-image">
      <%= image_tag @product.featured_image %>
    </div>
  <% end %>

  <section class="product-info">
    <% cache @product do %>
      <h1><%= @product.name %></h1>
      <div class="description">
        <%= @product.description %>
      </div>
    <% end %>

    <%= render "inventory", product: @product %>

    <% if authenticated? %>
      <%= link_to "Edit", edit_product_path(@product), class: "btn-edit" %>
      <%= button_to "Delete", @product, method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "btn-delete" %>
    <% end %>
  </section>
</section>
