<p><%= link_to "Back", products_path %></p>

<section class="product">
  <% if @product.featured_image.attached? %>
    <div class="product-image">
      <%= image_tag @product.featured_image %>
    </div>
  <% end %>

  <section class="product-info">
    <% cache @product do %>
      <h1><%= @product.name %></h1>
      <div class="description">
        <%= @product.description %>
      </div>
    <% end %>

    <%= render "inventory", product: @product %>

    <% if authenticated? %>
      <%= link_to "Edit", edit_product_path(@product), class: "btn-edit" %>
      <%= button_to "Delete", @product, method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "btn-delete" %>
    <% end %>
  </section>
</section>

<h2>Leave a Review</h2>

<%= form_with model: [@product, @product.reviews.build] do |form| %>
  <div>
    <%= form.label :name %>
    <%= form.text_field :name %>
  </div>

  <div>
    <%= form.label :rating %>
    <%= form.number_field :rating, in: 0..5 %>
  </div>

  <div>
    <%= form.label :body, "Review" %>
    <%= form.text_area :body %>
  </div>

  <div>
    <%= form.submit "Submit Review" %>
  </div>
<% end %>

<h2>Reviews</h2>

<% @product.reviews.each do |review| %>
  <div class="review">
    <strong><%= review.name %></strong>
    <p>Rating: <%= review.rating %> / 5</p>
    <p><%= review.body %></p>
  </div>
<% end %>
